{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@core/*": ["core/*"],
      "@games/*": ["games/*"],
      "@data/*": ["data/*"],
      "@bot/*": ["bot/*"]
    }
  },
  "include": [
    "core/**/*",
    "games/**/*",
    "data/**/*",
    "bot/**/*",
    "tests/**/*"
, "scripts/semantle/test-semantle.ts", "scripts/semantle/vocabulary-explorer.ts", "scripts/semantle/vocabulary-explorer-unfiltered.ts"  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ]
}