# Test Bot Configuration (for testing Discord integration)
DISCORD_TOKEN=your_test_bot_token_here
DISCORD_CLIENT_ID=your_test_bot_client_id_here
DISCORD_GUILD_ID=your_test_guild_id_here

# Semantle Bot Configuration
SEMANTLE_BOT_TOKEN=your_semantle_bot_token_here
SEMANTLE_CLIENT_ID=your_semantle_client_id_here

# Travle Bot Configuration  
TRAVLE_BOT_TOKEN=your_travle_bot_token_here
TRAVLE_CLIENT_ID=your_travle_client_id_here
DISCORD_CLIENT_SECRET=your_travle_client_secret_here

# Duotrigordle Bot Configuration
DUOTRIGORDLE_BOT_TOKEN=your_duotrigordle_bot_token_here
DUOTRIGORDLE_CLIENT_ID=your_duotrigordle_client_id_here

# Database Configuration
NODE_ENV=development
DATABASE_TYPE=sqlite
DATABASE_URL=discord-bot.db

# PostgreSQL Configuration (for production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=discord_puzzle_bot
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_MAX_CONNECTIONS=20

# Logging
LOG_LEVEL=info

# Property-based testing
FAST_CHECK_SEED=42